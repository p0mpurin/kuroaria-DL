{
  "manifest_version": 3,
  "name": "KuroAria DL",
  "version": "0.1.6",
  "description": "Send browser downloads to KuroAria DL",
  "permissions": ["downloads", "activeTab", "storage", "cookies"],
  "host_permissions": [
    "http://127.0.0.1/*",
    "ws://127.0.0.1/*",
    "https://*.gofile.io/*",
    "https://gofile.io/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Send to KuroAria DL",
    "default_popup": "popup.html"
  }
}
